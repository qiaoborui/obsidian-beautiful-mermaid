{
  "name": "obsidian-beautiful-mermaid",
  "version": "0.2.3",
  "private": true,
  "description": "Render Obsidian Mermaid diagrams with beautiful-mermaid SVG output.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qiaoborui/obsidian-beautiful-mermaid.git"
  },
  "type": "module",
  "scripts": {
    "assets": "bun scripts/generate-assets.ts",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs --production",
    "dev": "node esbuild.config.mjs",
    "typecheck": "tsc --noEmit --skipLibCheck"
  },
  "dependencies": {
    "beautiful-mermaid": "^1.1.3"
  },
  "devDependencies": {
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.8",
    "@types/node": "^20.11.0",
    "esbuild": "^0.24.0",
    "obsidian": "^1.8.7",
    "typescript": "^5.7.0"
  }
}
